{
  "name": "beetime",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "clean": "turbo run clean && rm -rf .turbo && rm -rf node_modules",
    "check": "turbo run check",
    "check:lint": "turbo run check:lint",
    "check:types": "turbo run check:types",
    "db:generate": "turbo -F @beetime/api db:generate",
    "db:migrate": "turbo -F @beetime/api db:migrate",
    "db:push": "turbo -F @beetime/api db:push",
    "db:studio": "turbo -F @beetime/api db:studio"
  },
  "devDependencies": {
    "turbo": "^2.9.6",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=22.18"
  },
  "packageManager": "bun@1.3.13",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalogs": {
      "core": {
        "@types/bun": "latest",
        "@types/node": "^25.1.0",
        "typescript": "6.0.3",
        "valibot": "^1.3.1"
      },
      "ui": {
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "react": "19.2.4",
        "react-dom": "19.2.4"
      }
    }
  }
}
