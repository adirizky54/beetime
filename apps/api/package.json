{
  "name": "@beetime/api",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "bun run --hot --port=8080 src/index.ts",
    "clean": "rm -rf .turbo && rm -rf node_modules",
    "check:format": "oxfmt --check",
    "check:lint": "oxlint",
    "check:types": "tsc --noEmit",
    "fix:format": "oxfmt .",
    "fix:lint": "oxlint --fix .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "email:dev": "email dev --dir=src/emails --port 3001"
  },
  "dependencies": {
    "@beetime/schema": "workspace:*",
    "@hono/valibot-validator": "^0.6.1",
    "better-auth": "^1.6.9",
    "drizzle-orm": "^0.45.2",
    "evlog": "^2.14.0",
    "hono": "^4.12.15",
    "nanoid": "^5.1.9",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-email": "6.0.1",
    "resend": "^6.12.2",
    "slugify": "^1.6.9",
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "@react-email/ui": "6.0.1",
    "@types/bun": "latest",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "drizzle-kit": "^0.31.10",
    "typescript": "6.0.3"
  }
}
